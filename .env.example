# ──────────────────────────────────────────────────────────────────
# Career Hub Pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────

# Google Gemini API key (required for all AI-powered scripts)
GEMINI_KEY=

# Speechmatics API key (required for Interview Mode transcription)
SPEECHMATICS_API_KEY=

# n8n server base URL (include port, no trailing slash)
N8N_BASE=http://localhost:5678

# n8n REST API key (JWT token — required for deploy_career_hub.py)
N8N_API_KEY=

# n8n workflow ID for the Career Hub UI (used by deploy_career_hub.py)
N8N_CAREER_HUB_WORKFLOW_ID=

# Path to the Career Hub HTML file (used by deploy_career_hub.py)
# Defaults to ../career_hub_v2.html relative to scripts/
CAREER_HUB_HTML=

# SQLite database path for jd_service.py
# Defaults to /opt/jd_service/jobs.db
JD_SERVICE_DB_PATH=
