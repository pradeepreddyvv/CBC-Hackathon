# ──────────────────────────────────────────────────────────────────
# InterviewCoach AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# ──────────────────────────────────────────────────────────────────

# AI Model via InsForge Model Gateway
AI_MODEL=google/gemini-2.5-flash-lite

# Gemini API Key (used only for vector embeddings)
GEMINI_API_KEY=

# ── InsForge Backend ──────────────────────────────────────────────
INSFORGE_PROJECT_URL=https://your-project.us-east.insforge.app
INSFORGE_API_KEY=
INSFORGE_ANON_KEY=
INSFORGE_DB_URL=postgresql://postgres:password@your-project.us-east.database.insforge.app:5432/insforge?sslmode=require

# ── Google OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Auth ──────────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-here
